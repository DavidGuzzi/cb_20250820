# Cloud Run Environment Configuration
# Copy this to .env and add your API key

# Required: OpenAI API Key for chatbot functionality
OPENAI_API_KEY=your-openai-api-key-here

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change-this-in-production-to-a-random-string

# Logging
LOG_LEVEL=INFO

# Cloud Run specific (automatically set)
PORT=8080